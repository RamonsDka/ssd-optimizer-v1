# Database — PostgreSQL (Docker Compose)
DATABASE_URL="postgresql://sdd_user:sdd_password@localhost:5432/sdd_optimizer?schema=public"

# Google Gemini AI — enables AI model categorization + discovery
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# OpenRouter — enables auto-sync of model dictionary (optional)
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# Next.js — public URL used for metadata + OpenRouter HTTP-Referer
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin Panel — basic password guard for /api/admin/* endpoints
# REQUIRED in production. Requests missing this header are rejected with 401.
# Send as: Authorization: Bearer <ADMIN_PASSWORD>
ADMIN_PASSWORD="change-me-in-production"

# Scoring Engine Version — controls which scoring engine is active
# v2 : LM Arena-based scoring (arena ELO + normalized weights) — fastest, no DB dependency
# v3 : UnifiedModelScores multi-dimensional (5D: coding, thinking, design, instruction, context)
# v4 : 17-dimensional scoring engine (A/B/C/D groups) — requires ModelCapabilities table populated
#
# IMPORTANT — Default API behavior:
#   POST /api/optimize now uses strategy="env" by default (changed from "auto").
#   This means SCORING_VERSION here is the single source of truth for production behavior.
#   Callers can still override per-request with ?version=v2|v3|v4|env query param.
#
# Migration guide:
#   - Use v3 (default) until ModelCapabilities table has data for ≥80% of models
#   - Switch to v4 after running: scripts/populate-model-capabilities.ts
#   - Instant rollback: set back to v3 (no redeploy needed if runtime env var)
#
# Debug inspection:
#   POST /api/optimize?debug=true  → includes 'debug' field with fallback metadata
SCORING_VERSION=v3
