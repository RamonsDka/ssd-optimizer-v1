// Prisma schema for SDD Team Optimizer
// DB: PostgreSQL — managed via Docker Compose

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Model + Provider ─────────────────────────────────────────────────────────

model Provider {
  id      String  @id // e.g. "openai", "anthropic"
  name    String
  logoUrl String?
  models  Model[]

  @@map("providers")
}

model Model {
  id             String   @id // e.g. "anthropic/claude-sonnet-4-5"
  name           String
  providerId     String
  provider       Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  tier           Tier
  contextWindow  Int
  costPer1M      Float    @default(0)
  strengths      String[]
  discoveredByAI Boolean  @default(false)
  lastSyncedAt   DateTime? // For LM Arena sync tracking
  updatedAt      DateTime @updatedAt

  selections  ModelSelection[]
  arenaScores LMArenaScore[]

  @@map("models")
}

// ─── LM Arena Integration ───────────────────────────────────────────────────

model LMArenaCategory {
  id          String   @id // slug e.g. "coding", "long-context"
  name        String
  description String?
  updatedAt   DateTime @updatedAt

  scores LMArenaScore[]

  @@map("lm_arena_categories")
}

model LMArenaScore {
  id                      String          @id @default(cuid())
  modelId                 String
  model                   Model           @relation(fields: [modelId], references: [id], onDelete: Cascade)
  categoryId              String
  category                LMArenaCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  leaderboardPublishDate  DateTime        // Source of truth from dataset
  rank                    Int?
  score                   Float
  votes                   Int?
  ci                      String?         // Confidence Interval e.g. "+5/-5"
  license                 String?
  syncedAt                DateTime        @default(now())

  @@unique([modelId, categoryId, leaderboardPublishDate])
  @@map("lm_arena_scores")
}

model SyncLog {
  id           String   @id @default(cuid())
  type         String   // "LMARENA" | "OPENROUTER"
  status       String   // "SUCCESS" | "FAILED" | "PARTIAL"
  totalModels  Int
  upserted     Int
  errors       Int
  errorDetails String?  @db.Text
  durationMs   Int
  createdAt    DateTime @default(now())

  @@map("sync_logs")
}

// ─── Optimization Jobs ────────────────────────────────────────────────────────

model OptimizationJob {
  id              String    @id @default(cuid())
  userInput       String    @db.Text
  results         Json      // TeamRecommendation JSON
  advancedOptions Json?     // AdvancedOptions snapshot at submission time
  status          JobStatus @default(PENDING)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  selections ModelSelection[]

  @@map("optimization_jobs")
}

model ModelSelection {
  id        String          @id @default(cuid())
  jobId     String
  job       OptimizationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  modelId   String
  model     Model           @relation(fields: [modelId], references: [id], onDelete: Cascade)
  phase     Int             // SDD phase number 1-10
  tier      Tier
  reasoning String          @db.Text
  score     Float           @default(0)
  createdAt DateTime        @default(now())

  @@map("model_selections")
}

// ─── Phase Recommendations (cached) ───────────────────────────────────────────

model PhaseRecommendation {
  id        String   @id @default(cuid())
  phase     Int      // 1-10 SDD phases
  modelId   String
  tier      Tier
  rationale String?  @db.Text
  reasoning String   @db.Text
  score     Float    @default(0)
  updatedAt DateTime @updatedAt

  @@unique([phase, modelId, tier])
  @@map("phase_recommendations")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Tier {
  PREMIUM
  BALANCED
  ECONOMIC
}

enum JobStatus {
  PENDING
  OPTIMIZING
  COMPLETED
  FAILED
}
